rules_version = '2';

// The frontend never talks to Firestore directly - it only calls the
// FastAPI backend, which uses the Admin SDK and bypasses these rules
// entirely. These rules exist purely as a safety net in case a Firebase
// Web SDK ever gets added to the frontend later: they keep wallet balances,
// orders, and admin credentials read-only (or fully closed) from any client.
service cloud.firestore {
  match /databases/{database}/documents {

    match /products/{productId} {
      allow read: if true;
      allow write: if false; // admin panel writes go through the backend
    }

    match /settings/{docId} {
      allow read: if false; // public settings are served via /api/settings/public
      allow write: if false;
    }

    match /users/{userId} {
      allow read, write: if false; // wallet_balance must only ever change via backend
    }

    match /orders/{orderId} {
      allow read, write: if false;
    }

    match /used_binance_txids/{txId} {
      allow read, write: if false;
    }

    match /admins/{email} {
      allow read, write: if false;
    }
  }
}
